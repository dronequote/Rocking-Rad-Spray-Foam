---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FinancingBanner from '../components/FinancingBanner.astro';
import MobileCTA from '../components/MobileCTA.astro';

interface Props {
  title: string;
  description: string;
  canonicalURL?: string;
  ogImage?: string;
  schema?: object;
  breadcrumbs?: { name: string; url: string }[];
}

const { title, description, canonicalURL, ogImage, schema, breadcrumbs } = Astro.props;
const siteURL = 'https://rockingradsprayfoam.com';
const canonical = canonicalURL || new URL(Astro.url.pathname, siteURL).href;
const ogImg = ogImage || `${siteURL}/images/og-default.jpg`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'InsulationContractor',
  '@id': `${siteURL}/#organization`,
  name: 'Rocking Rad Spray Foam LLC',
  image: `${siteURL}/images/logo.png`,
  url: siteURL,
  telephone: '(580) 320-5620',
  email: 'rockingradsprayfoam@gmail.com',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Ada',
    addressRegion: 'OK',
    postalCode: '74820',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 34.7746,
    longitude: -96.6783,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '07:00',
      closes: '17:00',
    },
  ],
  areaServed: [
    { '@type': 'City', name: 'Ada, Oklahoma' },
    { '@type': 'City', name: 'Oklahoma City, Oklahoma' },
    { '@type': 'City', name: 'Norman, Oklahoma' },
    { '@type': 'City', name: 'Tulsa, Oklahoma' },
    { '@type': 'City', name: 'Shawnee, Oklahoma' },
    { '@type': 'City', name: 'McAlester, Oklahoma' },
    { '@type': 'City', name: 'Durant, Oklahoma' },
    { '@type': 'City', name: 'Ardmore, Oklahoma' },
    { '@type': 'City', name: 'Stillwater, Oklahoma' },
  ],
  priceRange: '$$',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '5.0',
    reviewCount: '50',
  },
  sameAs: [
    'https://www.facebook.com/rockingradsprayfoam',
  ],
};

const breadcrumbSchema = breadcrumbs ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: crumb.url.startsWith('http') ? crumb.url : `${siteURL}${crumb.url}`,
  })),
} : null;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Rocking Rad Spray Foam" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@500;600;700;800&display=swap" rel="stylesheet" />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  {breadcrumbSchema && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />}
</head>
<body class="min-h-screen flex flex-col bg-white">
  <FinancingBanner />
  <Header />
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
  <MobileCTA />
</body>
</html>

---
interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaHref?: string;
  secondaryCTAText?: string;
  secondaryCTAHref?: string;
  backgroundImage?: string;
  compact?: boolean;
}

const {
  title,
  subtitle,
  ctaText = 'Get Your Free Estimate',
  ctaHref = '/contact',
  secondaryCTAText,
  secondaryCTAHref,
  backgroundImage,
  compact = false,
} = Astro.props;
---

<section class:list={[
  'relative bg-brand-blue text-white',
  compact ? 'py-12 lg:py-16' : 'py-16 lg:py-24',
]}>
  {backgroundImage && (
    <div class="absolute inset-0 bg-cover bg-center opacity-20" style={`background-image: url(${backgroundImage})`}></div>
  )}
  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h1 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl mb-4 lg:mb-6">
        {title}
      </h1>
      {subtitle && (
        <p class="text-lg sm:text-xl text-neutral-200 mb-6 lg:mb-8 leading-relaxed">
          {subtitle}
        </p>
      )}
      <div class="flex flex-col sm:flex-row gap-4">
        <a href={ctaHref} class="btn-primary text-base lg:text-lg px-6 lg:px-8 py-3 lg:py-4">
          {ctaText}
        </a>
        {secondaryCTAText && secondaryCTAHref && (
          <a href={secondaryCTAHref} class="inline-flex items-center justify-center px-6 lg:px-8 py-3 lg:py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-base lg:text-lg">
            {secondaryCTAText}
          </a>
        )}
      </div>
    </div>
  </div>
</section>

---
interface Props {
  headline?: string;
  subtext?: string;
}

const {
  headline = 'Ready to Cut Your Energy Bills?',
  subtext = 'Get a free, no-obligation estimate for your home or business. Most quotes delivered same-day.',
} = Astro.props;
---

<section class="bg-brand-blue text-white section-padding">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="font-display font-bold text-2xl sm:text-3xl lg:text-4xl mb-4">
      {headline}
    </h2>
    <p class="text-lg text-neutral-200 mb-8 max-w-2xl mx-auto">
      {subtext}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact" class="btn-primary text-lg px-8 py-4">
        Get Your Free Estimate
      </a>
      <a href="tel:5803205620" class="inline-flex items-center justify-center px-8 py-4 border-2 border-white text-white font-semibold rounded-lg hover:bg-white/10 transition-colors text-lg">
        📞 (580) 320-5620
      </a>
    </div>
    <p class="mt-6 text-sm text-neutral-300">
      30% Federal Tax Credit Available • 0% Financing Options • No Obligation
    </p>
  </div>
</section>

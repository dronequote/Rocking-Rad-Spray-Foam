---
interface Props {
  name: string;
  slug: string;
  description: string;
  icon?: string;
}

const { name, slug, description, icon } = Astro.props;

const iconPaths: Record<string, string> = {
  Wind: '<path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2" /><path d="M9.6 4.6A2 2 0 1 1 11 8H2" /><path d="M12.6 19.4A2 2 0 1 0 14 16H2" />',
  Shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />',
  Home: '<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" />',
  Warehouse: '<path d="M22 8.35V20a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8.35A2 2 0 0 1 3.26 6.5l8-3.2a2 2 0 0 1 1.48 0l8 3.2A2 2 0 0 1 22 8.35Z" /><path d="M6 18h12" /><path d="M6 14h12" /><rect width="12" height="12" x="6" y="10" />',
  Building2: '<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z" /><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2" /><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2" /><path d="M10 6h4" /><path d="M10 10h4" /><path d="M10 14h4" /><path d="M10 18h4" />',
};

const svgContent = icon ? iconPaths[icon] : undefined;
---

<a href={`/services/${slug}`} class="group block bg-white border border-neutral-200 rounded-xl p-6 hover:shadow-lg hover:border-brand-blue/20 transition-all">
  {svgContent && (
    <div class="bg-accent-orange/10 rounded-full p-3 w-fit mb-4">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-accent-orange"
        set:html={svgContent}
      />
    </div>
  )}
  <h3 class="font-display font-bold text-lg text-brand-blue group-hover:text-brand-blue-light transition-colors mb-2">
    {name}
  </h3>
  <p class="text-sm text-neutral-600 leading-relaxed mb-4">
    {description}
  </p>
  <span class="text-accent-orange font-semibold text-sm group-hover:translate-x-1 inline-block transition-transform">
    Learn More →
  </span>
</a>

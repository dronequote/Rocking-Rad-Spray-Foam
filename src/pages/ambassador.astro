---
import BaseLayout from '../layouts/BaseLayout.astro';
import AmbassadorSignup from '../components/AmbassadorSignup.tsx';

const siteURL = 'https://rockingradsprayfoam.com';
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Ambassador Program', url: '/ambassador' },
];
---

<BaseLayout
  title="Ambassador Program | Earn Rewards | Rocking Rad Spray Foam"
  description="Join the Rocking Rad Spray Foam ambassador program. Refer friends and neighbors for spray foam insulation and earn rewards for every successful referral."
  breadcrumbs={breadcrumbs}
>
  <!-- Hero -->
  <section class="bg-brand-blue text-white py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4">
        Refer. Earn. Repeat.
      </h1>
      <p class="text-lg sm:text-xl text-white/90 max-w-2xl mx-auto mb-8">
        Love your spray foam insulation? Share the experience with friends, family, and neighbors — and earn rewards for every referral.
      </p>
      <a href="#join" class="inline-block btn-primary text-lg px-8 py-3">
        Join the Program
      </a>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 lg:py-20 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-center text-neutral-900 mb-12">
        How It Works
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-orange rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-white">1</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Sign Up</h3>
          <p class="text-neutral-600 text-sm">
            Create your free ambassador account and get your unique referral link in seconds.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-orange rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-white">2</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Share Your Link</h3>
          <p class="text-neutral-600 text-sm">
            Share with friends, family, and neighbors via text, social media, email, or a printable QR code.
          </p>
        </div>
        <div class="text-center">
          <div class="w-16 h-16 bg-accent-orange rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-2xl font-bold text-white">3</span>
          </div>
          <h3 class="font-bold text-lg mb-2">Earn Rewards</h3>
          <p class="text-neutral-600 text-sm">
            When someone you referred gets a free estimate, you earn points toward rewards. It's that simple.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-center text-neutral-900 mb-12">
        Ambassador Benefits
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="bg-white border border-neutral-200 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">🎁</div>
          <h3 class="font-bold mb-1">Earn Rewards</h3>
          <p class="text-sm text-neutral-600">Points for every referral that books an estimate</p>
        </div>
        <div class="bg-white border border-neutral-200 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">📊</div>
          <h3 class="font-bold mb-1">Track Progress</h3>
          <p class="text-sm text-neutral-600">Real-time dashboard showing clicks, referrals, and earnings</p>
        </div>
        <div class="bg-white border border-neutral-200 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">🏆</div>
          <h3 class="font-bold mb-1">Leaderboard</h3>
          <p class="text-sm text-neutral-600">Compete with other ambassadors and climb the rankings</p>
        </div>
        <div class="bg-white border border-neutral-200 rounded-xl p-6 text-center">
          <div class="text-3xl mb-3">📱</div>
          <h3 class="font-bold mb-1">Easy Sharing</h3>
          <p class="text-sm text-neutral-600">One-click sharing via Facebook, text, email, WhatsApp & QR codes</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Signup Form -->
  <section id="join" class="py-16 lg:py-20 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-center text-neutral-900 mb-2">
        Join the Ambassador Program
      </h2>
      <p class="text-center text-neutral-600 mb-8 max-w-lg mx-auto">
        It's free to join. Sign up below and start sharing your referral link today.
      </p>
      <AmbassadorSignup client:visible />
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl sm:text-3xl font-bold text-center text-neutral-900 mb-10">
        Frequently Asked Questions
      </h2>
      <div class="space-y-6">
        <details class="bg-white border border-neutral-200 rounded-xl p-5 group">
          <summary class="font-semibold cursor-pointer list-none flex items-center justify-between">
            How does referral tracking work?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-neutral-600">
            When someone clicks your unique referral link, we track them for 90 days. If they request a free estimate during that window, you get credit for the referral automatically.
          </p>
        </details>
        <details class="bg-white border border-neutral-200 rounded-xl p-5 group">
          <summary class="font-semibold cursor-pointer list-none flex items-center justify-between">
            What rewards can I earn?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-neutral-600">
            You earn points for each successful referral. Points can be redeemed for gift cards, service discounts, and other rewards. Check your dashboard for the current reward catalog.
          </p>
        </details>
        <details class="bg-white border border-neutral-200 rounded-xl p-5 group">
          <summary class="font-semibold cursor-pointer list-none flex items-center justify-between">
            Do I need to be a past customer?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-neutral-600">
            No! Anyone can join the ambassador program. Whether you're a satisfied customer, a real estate agent, a contractor, or just someone who knows people who need insulation — you're welcome.
          </p>
        </details>
        <details class="bg-white border border-neutral-200 rounded-xl p-5 group">
          <summary class="font-semibold cursor-pointer list-none flex items-center justify-between">
            How do I access my dashboard?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-neutral-600">
            After signing up, you'll receive a magic link via email. Click it to access your dashboard where you can see your stats, share your link, view the leaderboard, and redeem rewards.
          </p>
        </details>
        <details class="bg-white border border-neutral-200 rounded-xl p-5 group">
          <summary class="font-semibold cursor-pointer list-none flex items-center justify-between">
            Is there a limit to how many people I can refer?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <p class="mt-3 text-sm text-neutral-600">
            No limit! The more people you refer, the more you earn. Our top ambassadors earn significant rewards by sharing with their networks.
          </p>
        </details>
      </div>
    </div>
  </section>
</BaseLayout>

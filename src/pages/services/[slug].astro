---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import CTASection from '../../components/CTASection.astro';
import QuoteForm from '../../components/QuoteForm.tsx';
import { services, type Service } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: Service;
}

const { service } = Astro.props;

const otherServices = services.filter((s) => s.slug !== service.slug);

const serviceImageMap: Record<string, { src: string; alt: string }> = {
  'open-cell-spray-foam': {
    src: '/images/open-cell-spray-foam-new-construction-walls-ceiling-oklahoma.jpg',
    alt: 'Open cell spray foam insulation applied to new construction walls and ceiling in Oklahoma',
  },
  'closed-cell-spray-foam': {
    src: '/images/closed-cell-spray-foam-metal-building-ceiling-walls-completed.jpg',
    alt: 'Closed cell spray foam insulation completed on metal building ceiling and walls in Oklahoma',
  },
  'attic-insulation': {
    src: '/images/open-cell-spray-foam-residential-arched-ceiling-new-home-oklahoma.jpg',
    alt: 'Spray foam attic insulation on a residential arched ceiling in a new Oklahoma home',
  },
  'metal-building-insulation': {
    src: '/images/spray-foam-insulation-metal-building-interior-completed-oklahoma.jpg',
    alt: 'Completed spray foam insulation inside a metal building in Oklahoma',
  },
  'commercial-insulation': {
    src: '/images/large-commercial-metal-building-before-insulation-oklahoma.jpg',
    alt: 'Large commercial metal building in Oklahoma ready for professional spray foam insulation',
  },
};

const serviceImage = serviceImageMap[service.slug];

// Parse markdown-style content into HTML
function parseContent(content: string): string {
  return content
    .split('\n\n')
    .map((block) => {
      if (block.startsWith('## ')) {
        return `<h2 class="font-display text-2xl font-bold text-brand-blue mt-8 mb-4">${block.replace('## ', '')}</h2>`;
      }
      if (block.startsWith('**') && block.includes('**')) {
        // Bold paragraph (sub-sections in content)
        return `<p class="text-neutral-700 mb-4">${block.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</p>`;
      }
      return `<p class="text-neutral-700 mb-4">${block.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</p>`;
    })
    .join('');
}

const contentHtml = parseContent(service.content);

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Services', url: '/services' },
  { name: service.shortName, url: `/services/${service.slug}` },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faqs.map((f) => ({
    '@type': 'Question',
    name: f.question,
    acceptedAnswer: { '@type': 'Answer', text: f.answer },
  })),
};

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: service.name,
  description: service.description,
  provider: {
    '@type': 'LocalBusiness',
    name: 'Rocking Rad Spray Foam LLC',
    telephone: '(580) 320-5620',
  },
  areaServed: {
    '@type': 'State',
    name: 'Oklahoma',
  },
};

const combinedSchema = [faqSchema, serviceSchema];
---

<BaseLayout
  title={service.seoTitle}
  description={service.seoDescription}
  schema={combinedSchema}
  breadcrumbs={breadcrumbs}
>
  <HeroSection
    title={service.name}
    subtitle={service.tagline}
    ctaText="Get Your Free Estimate"
    ctaHref="/contact"
    secondaryCTAText="Call (580) 320-5620"
    secondaryCTAHref="tel:5803205620"
    backgroundImage={service.heroImage}
  />

  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <!-- Service Image -->
          {serviceImage && (
            <div class="mb-10 rounded-xl overflow-hidden shadow-md">
              <img
                src={serviceImage.src}
                alt={serviceImage.alt}
                width="800"
                height="500"
                loading="lazy"
                class="w-full h-64 md:h-80 object-cover"
              />
            </div>
          )}

          <!-- Benefits -->
          <div class="mb-10">
            <h2 class="font-display text-2xl font-bold text-brand-blue mb-6">Key Benefits</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              {service.benefits.map((benefit) => (
                <div class="flex items-start gap-2">
                  <span class="text-accent-orange font-bold mt-0.5 shrink-0">✓</span>
                  <span class="text-neutral-700 text-sm">{benefit}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Specs -->
          <div class="flex flex-wrap gap-4 mb-10 p-4 bg-neutral-50 rounded-xl border border-neutral-200">
            <div>
              <span class="text-xs font-semibold text-neutral-500 uppercase">R-Value</span>
              <p class="font-display font-bold text-brand-blue">{service.rValue}</p>
            </div>
            <div class="border-l border-neutral-300 pl-4">
              <span class="text-xs font-semibold text-neutral-500 uppercase">Cost Range</span>
              <p class="font-display font-bold text-brand-blue">{service.costRange}</p>
            </div>
            <div class="border-l border-neutral-300 pl-4">
              <span class="text-xs font-semibold text-neutral-500 uppercase">Applications</span>
              <p class="font-display font-bold text-brand-blue text-sm">{service.applications.slice(0, 3).join(', ')}</p>
            </div>
          </div>

          <!-- Full Content -->
          <div class="prose max-w-none" set:html={contentHtml} />

          <!-- FAQ Section -->
          <div class="mt-12">
            <h2 class="font-display text-2xl font-bold text-brand-blue mb-6">Frequently Asked Questions</h2>
            <div class="space-y-4">
              {service.faqs.map((faq, i) => (
                <div class="border border-neutral-200 rounded-xl overflow-hidden">
                  <button
                    class="service-faq-toggle w-full flex items-center justify-between p-5 text-left hover:bg-neutral-50 transition-colors"
                    aria-expanded="false"
                  >
                    <span class="font-display font-bold text-brand-blue pr-4 text-sm">{faq.question}</span>
                    <svg class="service-faq-icon w-5 h-5 text-neutral-400 shrink-0 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>
                  <div class="service-faq-answer hidden px-5 pb-5">
                    <p class="text-neutral-600 text-sm">{faq.answer}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Quote Form -->
            <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200">
              <h3 class="font-display text-lg font-bold text-brand-blue mb-4">Get a Free Quote</h3>
              <QuoteForm client:visible />
            </div>

            <!-- Related Services -->
            <div class="bg-white rounded-xl p-6 border border-neutral-200">
              <h3 class="font-display text-lg font-bold text-brand-blue mb-4">Other Services</h3>
              <div class="space-y-3">
                {otherServices.map((s) => (
                  <a href={`/services/${s.slug}`} class="block p-3 rounded-lg hover:bg-neutral-50 transition-colors border border-transparent hover:border-neutral-200">
                    <p class="font-semibold text-sm text-brand-blue">{s.shortName}</p>
                    <p class="text-xs text-neutral-500 mt-0.5">{s.tagline}</p>
                  </a>
                ))}
              </div>
            </div>

            <!-- CTA Card -->
            <div class="bg-brand-blue rounded-xl p-6 text-white text-center">
              <h3 class="font-display text-lg font-bold mb-2">Ready to Get Started?</h3>
              <p class="text-blue-200 text-sm mb-4">Call us for a free, no-obligation estimate.</p>
              <a href="tel:5803205620" class="btn-primary w-full text-center block">
                Call (580) 320-5620
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<script>
  document.querySelectorAll('.service-faq-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      const answer = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.service-faq-icon') as HTMLElement;
      if (answer) answer.classList.toggle('hidden');
      if (icon) icon.style.transform = expanded ? '' : 'rotate(180deg)';
    });
  });
</script>

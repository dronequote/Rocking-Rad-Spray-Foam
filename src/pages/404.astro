---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page Not Found | Rocking Rad Spray Foam';
const description = 'The page you\'re looking for doesn\'t exist. Find spray foam insulation services, FAQs, and contact information for Rocking Rad Spray Foam.';

const helpfulLinks = [
  { label: 'Homepage', href: '/', description: 'Start from the beginning' },
  { label: 'Our Services', href: '/services', description: 'Browse spray foam insulation services' },
  { label: 'Contact Us', href: '/contact', description: 'Get a free estimate or ask a question' },
  { label: 'FAQ', href: '/faq', description: 'Find answers to common questions' },
];
---

<BaseLayout title={title} description={description}>
  <section class="section-padding bg-white min-h-[60vh] flex items-center">
    <div class="container-narrow w-full">
      <div class="max-w-2xl mx-auto text-center">
        <p class="text-8xl font-display font-extrabold text-brand-blue/10 mb-4">404</p>
        <h1 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">Page Not Found</h1>
        <p class="text-lg text-neutral-600 mb-10">Sorry, the page you're looking for doesn't exist or has been moved. Let us help you find what you need.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
          {helpfulLinks.map((link) => (
            <a href={link.href} class="block bg-neutral-50 rounded-xl p-5 border border-neutral-200 hover:border-accent-orange hover:shadow-md transition-all text-left group">
              <h2 class="font-display font-bold text-brand-blue group-hover:text-accent-orange transition-colors mb-1">{link.label}</h2>
              <p class="text-sm text-neutral-500">{link.description}</p>
            </a>
          ))}
        </div>

        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/" class="btn-primary">Go to Homepage</a>
          <a href="tel:5803205620" class="btn-outline">Call (580) 320-5620</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTASection from '../components/CTASection.astro';
import { company } from '../data/company';

const title = 'About Rocking Rad Spray Foam | Oklahoma';
const description = 'Meet the team behind Oklahoma\'s trusted spray foam insulation company. Woman-owned, minority-owned, BBB A+ rated, licensed home builders. Learn our story.';

const differentiators = [
  { title: 'Woman-Owned Business', text: 'Mariah helps lead our operations, and we\'re proud to be a certified woman-owned business serving Oklahoma.' },
  { title: 'Minority-Owned Business', text: 'Diversity in the trades matters. We bring a different perspective and a commitment to excellence.' },
  { title: 'BBB A+ Rated', text: 'Our Better Business Bureau A+ rating reflects our commitment to honest pricing, quality work, and customer satisfaction.', link: 'https://www.bbb.org/us/ok/ada/profile/insulation-contractors/rocking-rad-spray-foam-llc-0995-90120194' },
  { title: 'Licensed Home Builders', text: 'We\'re not just insulation contractors — we\'re licensed home builders who understand construction from the ground up.' },
  { title: '94% Facebook Recommendation', text: '94% of people who\'ve interacted with us on Facebook recommend us. That\'s real trust from real customers.' },
  { title: 'Oklahoma Born & Based', text: 'We live here, we work here, and we understand Oklahoma\'s climate, building styles, and what homeowners need.' },
];

const notFitItems = [
  'You want the absolute cheapest price regardless of quality — we use premium materials and won\'t cut corners.',
  'You need it done yesterday with no scheduling flexibility — we book out because demand is high, and we won\'t rush a job.',
  'You\'re looking for a quick DIY consultation — spray foam requires professional equipment and certified installers.',
  'You want someone who\'ll just spray and leave — we assess, recommend, install, and inspect every job.',
];
---

<BaseLayout title={title} description={description} breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'About', url: '/about' }]}>
  <HeroSection
    title="Oklahoma Owned. Oklahoma Proud."
    subtitle="We're a family-run spray foam insulation company built on honest work, premium materials, and treating every home like our own."
    ctaText="Get Your Free Estimate"
    ctaHref="/contact"
    backgroundImage="/images/hero-about.jpg"
  />

  <!-- Our Story -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-6">Our Story</h2>
          <div class="prose prose-lg text-neutral-700 space-y-4">
            <p>Rocking Rad Spray Foam started with a simple idea: Oklahoma homeowners and business owners deserve an insulation contractor who shows up on time, does the job right, and charges a fair price. That shouldn't be radical, but in this industry, it kind of is.</p>
            <p><strong>Rayce</strong> is our lead operator — the one on-site making sure every square inch gets proper coverage. He's meticulous about preparation, application thickness, and cleanup. If it's not right, it gets fixed before we leave.</p>
            <p><strong>Kyle</strong> handles sales and customer relationships. He's the one who walks your property, listens to your concerns, and recommends the right solution — not the most expensive one. He'll tell you if spray foam isn't the right fit for your project (yes, that happens sometimes).</p>
            <p><strong>Mariah</strong> keeps the business running behind the scenes — scheduling, bookkeeping, customer follow-up, and making sure nothing falls through the cracks. She's the reason your estimate shows up on time and your questions get answered.</p>
            <p>Together, we've built a company that we're proud of. Not the biggest spray foam company in Oklahoma — but we think we're the most honest, and our customers seem to agree.</p>
          </div>
        </div>
        <div class="space-y-4">
          <img
            src="/images/rocking-rad-spray-foam-truck-trailer-job-site-oklahoma.jpg"
            alt="Rocking Rad Spray Foam truck and trailer at a job site in Oklahoma"
            width="600"
            height="400"
            loading="lazy"
            class="w-full rounded-xl shadow-md"
          />
          <img
            src="/images/rocking-rad-spray-foam-trailer-grain-bin-job-site-oklahoma.jpg"
            alt="Rocking Rad Spray Foam trailer set up at a grain bin insulation job site in Oklahoma"
            width="600"
            height="400"
            loading="lazy"
            class="w-full rounded-xl shadow-md"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Our Team at Work -->
  <section class="section-padding bg-white border-t border-neutral-100">
    <div class="container-narrow">
      <div class="text-center mb-10">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">Our Team at Work</h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">Every job gets our full attention — from preparation through final inspection.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="rounded-xl overflow-hidden shadow-md">
          <img
            src="/images/spray-foam-insulation-technician-full-safety-gear-oklahoma.jpg"
            alt="Spray foam insulation technician in full safety gear on an Oklahoma job site"
            width="600"
            height="400"
            loading="lazy"
            class="w-full h-64 object-cover object-top"
          />
          <div class="p-4 bg-neutral-50">
            <p class="font-display font-bold text-brand-blue text-sm">Full Safety Gear, Every Job</p>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden shadow-md">
          <img
            src="/images/spray-foam-installer-spraying-metal-building-from-lift-oklahoma.jpg"
            alt="Spray foam installer spraying insulation in a metal building from a lift in Oklahoma"
            width="600"
            height="400"
            loading="lazy"
            class="w-full h-64 object-cover object-top"
          />
          <div class="p-4 bg-neutral-50">
            <p class="font-display font-bold text-brand-blue text-sm">Professional Equipment for Every Project</p>
          </div>
        </div>
        <div class="rounded-xl overflow-hidden shadow-md">
          <img
            src="/images/spray-foam-technician-trimming-insulation-on-scaffold.jpg"
            alt="Spray foam technician trimming insulation on scaffold for a clean finish"
            width="600"
            height="400"
            loading="lazy"
            class="w-full h-64 object-cover object-top"
          />
          <div class="p-4 bg-neutral-50">
            <p class="font-display font-bold text-brand-blue text-sm">Precision Trimming for Clean Results</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Makes Us Different -->
  <section class="section-padding bg-neutral-50">
    <div class="container-narrow">
      <div class="text-center mb-12">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">What Makes Us Different</h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">We're not your typical spray foam company. Here's what sets us apart.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {differentiators.map((item) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
            <h3 class="font-display text-lg font-bold text-brand-blue mb-2">{item.title}</h3>
            <p class="text-neutral-600 text-sm">{item.text}</p>
            {item.link && (
              <a href={item.link} target="_blank" rel="noopener noreferrer" class="inline-block mt-2 text-sm text-accent-orange hover:text-accent-orange-dark font-medium">
                View Our BBB Profile →
              </a>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Who We're NOT a Good Fit For -->
  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="max-w-3xl mx-auto">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">Who We're NOT a Good Fit For</h2>
        <p class="text-lg text-neutral-600 mb-8">We believe in transparency. We'd rather be upfront than waste your time. We're probably not the right fit if:</p>
        <div class="space-y-4">
          {notFitItems.map((item) => (
            <div class="flex items-start gap-3 bg-neutral-50 rounded-lg p-4 border border-neutral-200">
              <span class="text-accent-orange font-bold text-xl mt-0.5">×</span>
              <p class="text-neutral-700">{item}</p>
            </div>
          ))}
        </div>
        <div class="mt-8 bg-brand-blue/5 rounded-xl p-6 border border-brand-blue/20">
          <p class="text-brand-blue font-medium text-lg mb-2">But if you want it done right the first time...</p>
          <p class="text-neutral-600 mb-4">If you value quality materials, honest communication, and a crew that treats your property with respect — we'd love to earn your business.</p>
          <a href="/contact" class="btn-primary">Get Your Free Estimate</a>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

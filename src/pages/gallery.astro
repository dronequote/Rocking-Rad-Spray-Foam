---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import CTASection from '../components/CTASection.astro';

const title = 'Project Gallery | Rocking Rad Spray Foam';
const description = 'See our spray foam insulation work across Oklahoma. Attic, metal building, pole barn, commercial, and residential projects. Before and after photos.';

const projects = [
  {
    title: 'Metal Building — Bare Interior Before Insulation',
    type: 'Metal Building',
    foam: 'Before',
    description: 'A bare metal building interior before spray foam insulation — exposed steel framing with no thermal protection.',
    image: '/images/bare-metal-building-interior-before-spray-foam-insulation.jpg',
  },
  {
    title: 'Metal Building — Closed Cell Completed',
    type: 'Metal Building',
    foam: 'Closed Cell',
    description: 'Closed cell spray foam fully applied to ceiling and walls of a metal building, providing a complete thermal and moisture barrier.',
    image: '/images/closed-cell-spray-foam-metal-building-ceiling-walls-completed.jpg',
  },
  {
    title: 'Large Commercial Metal Building — Before Insulation',
    type: 'Commercial',
    foam: 'Before',
    description: 'A large commercial metal building in Oklahoma before insulation — ready for professional spray foam application.',
    image: '/images/large-commercial-metal-building-before-insulation-oklahoma.jpg',
  },
  {
    title: 'New Construction — Open Cell Walls & Ceiling',
    type: 'Residential',
    foam: 'Open Cell',
    description: 'Open cell spray foam applied to walls and ceiling during new home construction in Oklahoma for maximum energy efficiency.',
    image: '/images/open-cell-spray-foam-new-construction-walls-ceiling-oklahoma.jpg',
  },
  {
    title: 'Residential Arched Ceiling — Open Cell Foam',
    type: 'Residential',
    foam: 'Open Cell',
    description: 'Open cell spray foam insulation on a residential arched ceiling in a new Oklahoma home build, ensuring full coverage on complex geometry.',
    image: '/images/open-cell-spray-foam-residential-arched-ceiling-new-home-oklahoma.jpg',
  },
  {
    title: 'Job Site — Spray Foam Trailer at Grain Bin',
    type: 'On the Job',
    foam: 'Closed Cell',
    description: 'Rocking Rad Spray Foam trailer set up at a grain bin insulation job site in Oklahoma.',
    image: '/images/rocking-rad-spray-foam-trailer-grain-bin-job-site-oklahoma.jpg',
  },
  {
    title: 'Job Site — Truck & Trailer Ready to Go',
    type: 'On the Job',
    foam: 'Equipment',
    description: 'Rocking Rad Spray Foam truck and trailer at an Oklahoma job site, fully equipped for professional insulation installation.',
    image: '/images/rocking-rad-spray-foam-truck-trailer-job-site-oklahoma.jpg',
  },
  {
    title: 'Crew Member with Equipment — Metal Building',
    type: 'On the Job',
    foam: 'In Progress',
    description: 'A spray foam crew member with professional equipment inside a metal building, ready for insulation application.',
    image: '/images/spray-foam-crew-member-equipment-low-angle-metal-building.jpg',
  },
  {
    title: 'Close-Up — Spray Foam Gun Applying Closed Cell',
    type: 'Application Detail',
    foam: 'Closed Cell',
    description: 'Close-up of a spray foam gun applying closed cell insulation — precision application for consistent coverage.',
    image: '/images/spray-foam-gun-applying-closed-cell-insulation-closeup.jpg',
  },
  {
    title: 'Installer Spraying from Lift — Metal Building',
    type: 'Metal Building',
    foam: 'In Progress',
    description: 'Spray foam installer applying insulation from a lift in a large Oklahoma metal building for full ceiling coverage.',
    image: '/images/spray-foam-installer-spraying-metal-building-from-lift-oklahoma.jpg',
  },
  {
    title: 'Contractor Spraying Metal Building Wall',
    type: 'Metal Building',
    foam: 'In Progress',
    description: 'Spray foam insulation contractor spraying a metal building wall in Oklahoma — our team in action.',
    image: '/images/spray-foam-insulation-contractor-spraying-metal-building-wall-oklahoma.jpg',
  },
  {
    title: 'Metal Building Interior — Insulation Completed',
    type: 'Metal Building',
    foam: 'Closed Cell',
    description: 'Completed spray foam insulation inside a metal building in Oklahoma — full thermal envelope ready for finishing.',
    image: '/images/spray-foam-insulation-metal-building-interior-completed-oklahoma.jpg',
  },
  {
    title: 'Quonset Hut — Spray Foam Completed',
    type: 'Metal Building',
    foam: 'Closed Cell',
    description: 'Spray foam insulation fully applied inside a quonset hut arch building — complete coverage on curved surfaces.',
    image: '/images/spray-foam-insulation-quonset-hut-arch-building-completed.jpg',
  },
  {
    title: 'Shipping Container — Spray Foam Interior',
    type: 'Specialty',
    foam: 'Closed Cell',
    description: 'Spray foam insulation applied to the interior of a shipping container in Oklahoma for climate-controlled conversion.',
    image: '/images/spray-foam-insulation-shipping-container-interior-oklahoma.jpg',
  },
  {
    title: 'Technician in Full Safety Gear',
    type: 'On the Job',
    foam: 'Safety',
    description: 'Spray foam insulation technician in full safety gear on an Oklahoma job site — safety is always our priority.',
    image: '/images/spray-foam-insulation-technician-full-safety-gear-oklahoma.jpg',
  },
  {
    title: 'Wall Application Detail — Spray Foam',
    type: 'Application Detail',
    foam: 'In Progress',
    description: 'Detailed view of spray foam insulation being applied to a wall in Oklahoma — even coverage for maximum performance.',
    image: '/images/spray-foam-insulation-wall-application-detail-oklahoma.jpg',
  },
  {
    title: 'Technician Trimming Insulation on Scaffold',
    type: 'Finishing',
    foam: 'Finishing',
    description: 'Spray foam technician trimming insulation on a scaffold for a clean, professional finish.',
    image: '/images/spray-foam-technician-trimming-insulation-on-scaffold.jpg',
  },
];
---

<BaseLayout title={title} description={description}>
  <HeroSection
    title="Our Work Speaks for Itself"
    subtitle="Browse real spray foam insulation projects from across Oklahoma. Every project completed to the highest standards."
    ctaText="Start Your Project"
    ctaHref="/contact"
    backgroundImage="/images/hero-gallery.jpg"
  />

  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project, i) => (
          <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-neutral-200 hover:shadow-md transition-shadow">
            <button
              type="button"
              class="gallery-trigger w-full cursor-pointer"
              data-index={i}
              data-src={project.image}
              data-alt={project.description}
              data-title={project.title}
              aria-label={`View full size: ${project.title}`}
            >
              <img
                src={project.image}
                alt={project.description}
                width="600"
                height="400"
                loading="lazy"
                class="w-full h-56 object-cover hover:scale-105 transition-transform duration-300"
              />
            </button>
            <div class="p-5">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-xs font-semibold bg-brand-blue/10 text-brand-blue px-2 py-0.5 rounded-full">{project.type}</span>
                <span class="text-xs font-semibold bg-accent-orange/10 text-accent-orange px-2 py-0.5 rounded-full">{project.foam}</span>
              </div>
              <h3 class="font-display font-bold text-brand-blue mb-2">{project.title}</h3>
              <p class="text-sm text-neutral-600">{project.description}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="text-center mt-12">
        <p class="text-neutral-600 mb-4">Want to see your project here? Every job we complete is a project we're proud of.</p>
        <a href="/contact" class="btn-primary">Get Your Free Estimate</a>
      </div>
    </div>
  </section>

  <CTASection />

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-[100] hidden bg-black/90 flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-label="Image viewer">
    <button id="lightbox-close" type="button" class="absolute top-4 right-4 text-white hover:text-neutral-300 z-10" aria-label="Close image viewer">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <button id="lightbox-prev" type="button" class="absolute left-4 top-1/2 -translate-y-1/2 text-white hover:text-neutral-300 z-10 p-2" aria-label="Previous image">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button id="lightbox-next" type="button" class="absolute right-4 top-1/2 -translate-y-1/2 text-white hover:text-neutral-300 z-10 p-2" aria-label="Next image">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    </button>
    <div class="max-w-5xl max-h-[90vh] flex flex-col items-center">
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[80vh] object-contain rounded-lg" />
      <p id="lightbox-caption" class="text-white text-center mt-3 text-sm font-medium max-w-lg"></p>
    </div>
  </div>
</BaseLayout>

<script>
  const lightbox = document.getElementById('lightbox')!;
  const lbImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lbCaption = document.getElementById('lightbox-caption')!;
  const triggers = document.querySelectorAll('.gallery-trigger');
  const items = Array.from(triggers).map(t => ({
    src: t.getAttribute('data-src')!,
    alt: t.getAttribute('data-alt')!,
    title: t.getAttribute('data-title')!,
  }));
  let current = 0;

  function show(index: number) {
    current = ((index % items.length) + items.length) % items.length;
    lbImg.src = items[current].src;
    lbImg.alt = items[current].alt;
    lbCaption.textContent = items[current].title;
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function hide() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  triggers.forEach(t => t.addEventListener('click', () => show(Number(t.getAttribute('data-index')))));
  document.getElementById('lightbox-close')!.addEventListener('click', hide);
  document.getElementById('lightbox-prev')!.addEventListener('click', () => show(current - 1));
  document.getElementById('lightbox-next')!.addEventListener('click', () => show(current + 1));
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) hide(); });
  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') hide();
    if (e.key === 'ArrowLeft') show(current - 1);
    if (e.key === 'ArrowRight') show(current + 1);
  });
</script>

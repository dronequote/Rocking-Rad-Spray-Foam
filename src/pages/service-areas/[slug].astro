---
import BaseLayout from '../../layouts/BaseLayout.astro';
import HeroSection from '../../components/HeroSection.astro';
import CTASection from '../../components/CTASection.astro';
import QuoteForm from '../../components/QuoteForm.tsx';
import { cities, type City } from '../../data/cities';
import { services } from '../../data/services';

export function getStaticPaths() {
  return cities.map((city) => ({
    params: { slug: city.slug },
    props: { city },
  }));
}

interface Props {
  city: City;
}

const { city } = Astro.props;

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Service Areas', url: '/service-areas' },
  { name: city.name, url: `/service-areas/${city.slug}` },
];

const nearbyAreas = cities.filter((c) => city.nearbyAreas.includes(c.name)).slice(0, 4);
const otherAreas = nearbyAreas.length > 0 ? nearbyAreas : cities.filter((c) => c.slug !== city.slug).slice(0, 4);

// Parse markdown-style content into HTML
function parseContent(content: string): string {
  return content
    .split('\n\n')
    .map((block) => {
      if (block.startsWith('## ')) {
        return `<h2 class="font-display text-2xl font-bold text-brand-blue mt-8 mb-4">${block.replace('## ', '')}</h2>`;
      }
      if (block.startsWith('**') && block.includes('**')) {
        return `<p class="text-neutral-700 mb-4">${block.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</p>`;
      }
      return `<p class="text-neutral-700 mb-4">${block.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')}</p>`;
    })
    .join('');
}

const contentHtml = parseContent(city.content);
---

<BaseLayout
  title={city.seoTitle}
  description={city.seoDescription}
  breadcrumbs={breadcrumbs}
>
  <HeroSection
    title={`Spray Foam Insulation in ${city.name}, Oklahoma`}
    subtitle={`${city.name}'s trusted spray foam contractor. Professional installation for homes, metal buildings, and commercial properties.`}
    ctaText="Get Your Free Estimate"
    ctaHref="/contact"
    secondaryCTAText="Call (580) 320-5620"
    secondaryCTAHref="tel:5803205620"
    backgroundImage="/images/hero-service-areas.jpg"
  />

  <section class="section-padding bg-white">
    <div class="container-narrow">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main Content -->
        <div class="lg:col-span-2">
          <h2 class="font-display text-2xl md:text-3xl font-bold text-brand-blue mb-6">
            Spray Foam Insulation Services in {city.name}
          </h2>

          <!-- City Content -->
          <div class="prose max-w-none mb-10" set:html={contentHtml} />

          <!-- Local Factors -->
          {city.localFactors && city.localFactors.length > 0 && (
            <div class="mb-10">
              <h3 class="font-display text-xl font-bold text-brand-blue mb-4">Why {city.name} Properties Need Spray Foam</h3>
              <div class="space-y-3">
                {city.localFactors.map((factor) => (
                  <div class="flex items-start gap-3 bg-neutral-50 rounded-lg p-4 border border-neutral-200">
                    <span class="text-accent-orange font-bold mt-0.5 shrink-0">✓</span>
                    <p class="text-neutral-700 text-sm">{factor}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          <!-- Services Available -->
          <div class="mb-10">
            <h3 class="font-display text-xl font-bold text-brand-blue mb-6">Services Available in {city.name}</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {services.map((service) => (
                <a href={`/services/${service.slug}`} class="block bg-white rounded-xl p-5 border border-neutral-200 hover:border-accent-orange hover:shadow-md transition-all group">
                  <h4 class="font-display font-bold text-brand-blue group-hover:text-accent-orange transition-colors mb-1">{service.shortName}</h4>
                  <p class="text-xs text-neutral-500 mb-2">{service.rValue} | {service.costRange}</p>
                  <p class="text-sm text-neutral-600">{service.tagline}</p>
                </a>
              ))}
            </div>
          </div>

          <!-- ZIP Codes -->
          <div class="mb-10">
            <h3 class="font-display text-xl font-bold text-brand-blue mb-4">ZIP Codes We Serve in {city.name}</h3>
            <div class="flex flex-wrap gap-2">
              {city.zipCodes.map((zip) => (
                <span class="bg-neutral-50 text-neutral-700 px-4 py-2 rounded-lg border border-neutral-200 font-medium text-sm">{zip}</span>
              ))}
            </div>
          </div>

          <!-- Nearby Areas -->
          <div>
            <h3 class="font-display text-xl font-bold text-brand-blue mb-4">Nearby Service Areas</h3>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
              {otherAreas.map((area) => (
                <a href={`/service-areas/${area.slug}`} class="text-center bg-neutral-50 rounded-lg p-3 border border-neutral-200 hover:border-accent-orange transition-all">
                  <p class="font-display font-bold text-brand-blue text-sm">{area.name}</p>
                  <p class="text-xs text-neutral-500">{area.state}</p>
                </a>
              ))}
            </div>
            <div class="mt-3">
              <p class="text-sm text-neutral-500">Also serving: {city.nearbyAreas.join(', ')}</p>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Quote Form -->
            <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200">
              <h3 class="font-display text-lg font-bold text-brand-blue mb-4">Free Estimate in {city.name}</h3>
              <QuoteForm client:visible />
            </div>

            <!-- CTA Card -->
            <div class="bg-brand-blue rounded-xl p-6 text-white text-center">
              <h3 class="font-display text-lg font-bold mb-2">Serving {city.name}, {city.state}</h3>
              <p class="text-blue-200 text-sm mb-4">Call for a free, no-obligation estimate on your project.</p>
              <a href="tel:5803205620" class="btn-primary w-full text-center block">
                Call (580) 320-5620
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import StatsBar from '../components/StatsBar.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTASection from '../components/CTASection.astro';
import QuoteForm from '../components/QuoteForm.tsx';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';
import { company } from '../data/company';
import { cities } from '../data/cities';

const title = 'Spray Foam Insulation Oklahoma | Rocking Rad';
const description = 'Oklahoma\'s trusted spray foam insulation contractor. Woman-owned, BBB A+ rated. Open cell, closed cell, attic & metal building insulation. Free estimates. (580) 320-5620';

const benefitItems = [
  { title: 'Cut Energy Bills 30–50%', text: 'Spray foam creates an airtight seal that stops conditioned air from escaping through gaps fiberglass can\'t reach.' },
  { title: 'Year-Round Comfort', text: 'Eliminate hot and cold spots. Your home stays comfortable whether it\'s 110°F in July or an ice storm in January.' },
  { title: 'Permanent Solution', text: 'Unlike fiberglass that sags and compresses, spray foam maintains its R-value for the lifetime of your structure.' },
  { title: 'Stops Moisture & Mold', text: 'Closed cell foam is a built-in vapor barrier. No more condensation on metal buildings or moisture in crawl spaces.' },
  { title: 'Built-In Vapor Barrier', text: 'Closed cell spray foam doubles as a moisture and vapor barrier — no separate product needed. One application, multiple functions.' },
  { title: 'Increases Property Value', text: 'Energy-efficient homes sell faster and for more. Spray foam is a permanent upgrade that pays dividends at resale.' },
];

const displayTestimonials = testimonials.slice(0, 3);
---

<BaseLayout title={title} description={description}>
  <div class="pb-20 lg:pb-0">
    <!-- Hero -->
    <HeroSection
      title="Spray Foam Insulation That Pays for Itself"
      subtitle="Oklahoma's woman-owned, BBB A+ rated insulation contractor. Cut your energy bills 30–50% with professional spray foam installation."
      ctaText="Get Your Free Estimate"
      ctaHref="/contact"
      secondaryCTAText="Call (580) 320-5620"
      secondaryCTAHref="tel:5803205620"
      backgroundImage="/images/spray-foam-insulation-contractor-spraying-metal-building-wall-oklahoma.jpg"
    />

    <!-- Stats Bar -->
    <StatsBar />

    <!-- Services Grid -->
    <section class="section-padding bg-white">
      <div class="container-narrow">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">Our Spray Foam Services</h2>
          <p class="text-lg text-neutral-600 max-w-2xl mx-auto">From residential attics to commercial metal buildings, we have the right insulation solution for every project.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {services.map((service) => (
            <ServiceCard name={service.name} slug={service.slug} description={service.description} icon={service.icon} />
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/services" class="btn-secondary">View All Services</a>
        </div>
      </div>
    </section>

    <!-- Why Spray Foam Benefits -->
    <section class="section-padding bg-neutral-50">
      <div class="container-narrow">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">Why Oklahoma Homeowners Choose Spray Foam</h2>
          <p class="text-lg text-neutral-600 max-w-2xl mx-auto">Spray foam isn't just insulation — it's an investment that pays you back every month.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {benefitItems.map((item) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-200">
              <h3 class="font-display text-lg font-bold text-brand-blue mb-2">{item.title}</h3>
              <p class="text-neutral-600 text-sm">{item.text}</p>
            </div>
          ))}
        </div>
        <div class="text-center mt-10">
          <a href="/why-spray-foam" class="btn-outline">Learn More About Spray Foam</a>
        </div>
      </div>
    </section>

    <!-- Project Photos -->
    <section class="section-padding bg-white">
      <div class="container-narrow">
        <div class="text-center mb-10">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">Recent Projects Across Oklahoma</h2>
          <p class="text-lg text-neutral-600 max-w-2xl mx-auto">From metal buildings to new construction homes, see the quality of our spray foam insulation work.</p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="rounded-xl overflow-hidden shadow-md">
            <img
              src="/images/closed-cell-spray-foam-metal-building-ceiling-walls-completed.jpg"
              alt="Completed closed cell spray foam insulation on metal building ceiling and walls in Oklahoma"
              width="600"
              height="400"
              loading="lazy"
              class="w-full h-64 object-cover"
            />
            <div class="p-4 bg-neutral-50">
              <p class="font-display font-bold text-brand-blue text-sm">Metal Building — Closed Cell Foam</p>
              <p class="text-xs text-neutral-500 mt-1">Full coverage on ceiling and walls</p>
            </div>
          </div>
          <div class="rounded-xl overflow-hidden shadow-md">
            <img
              src="/images/open-cell-spray-foam-residential-arched-ceiling-new-home-oklahoma.jpg"
              alt="Open cell spray foam insulation on residential arched ceiling in new Oklahoma home"
              width="600"
              height="400"
              loading="lazy"
              class="w-full h-64 object-cover"
            />
            <div class="p-4 bg-neutral-50">
              <p class="font-display font-bold text-brand-blue text-sm">New Home — Open Cell Foam</p>
              <p class="text-xs text-neutral-500 mt-1">Arched ceiling insulation for new construction</p>
            </div>
          </div>
          <div class="rounded-xl overflow-hidden shadow-md">
            <img
              src="/images/spray-foam-insulation-metal-building-interior-completed-oklahoma.jpg"
              alt="Completed spray foam insulation inside a metal building in Oklahoma"
              width="600"
              height="400"
              loading="lazy"
              class="w-full h-64 object-cover"
            />
            <div class="p-4 bg-neutral-50">
              <p class="font-display font-bold text-brand-blue text-sm">Metal Building — Completed Interior</p>
              <p class="text-xs text-neutral-500 mt-1">Full insulation coverage, ready for finishing</p>
            </div>
          </div>
        </div>
        <div class="text-center mt-8">
          <a href="/gallery" class="btn-outline">View Full Project Gallery</a>
        </div>
      </div>
    </section>

    <!-- Savings Calculator Teaser -->
    <section class="section-padding bg-brand-blue">
      <div class="container-narrow">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">How Much Could You Save?</h2>
          <p class="text-lg text-blue-200 mb-8">Find out in 60 seconds. Enter a few details about your home and see your estimated energy savings, payback period, and 20-year ROI.</p>
          <form
            id="savings-teaser-form"
            class="bg-white/10 backdrop-blur rounded-2xl p-6 sm:p-8 border border-white/20"
          >
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
              <div>
                <label for="teaser-zip" class="block text-sm font-semibold text-white mb-1.5">ZIP Code</label>
                <input
                  type="text"
                  id="teaser-zip"
                  name="zip"
                  inputmode="numeric"
                  maxlength="5"
                  placeholder="e.g. 74820"
                  class="w-full px-4 py-3 rounded-lg bg-white text-neutral-800 placeholder-neutral-400 border-0 focus:ring-2 focus:ring-accent-orange focus:outline-none"
                />
              </div>
              <div>
                <label for="teaser-sqft" class="block text-sm font-semibold text-white mb-1.5">Square Footage</label>
                <input
                  type="number"
                  id="teaser-sqft"
                  name="sqft"
                  min="800"
                  max="5000"
                  placeholder="e.g. 1900"
                  class="w-full px-4 py-3 rounded-lg bg-white text-neutral-800 placeholder-neutral-400 border-0 focus:ring-2 focus:ring-accent-orange focus:outline-none"
                />
              </div>
              <div>
                <label for="teaser-condition" class="block text-sm font-semibold text-white mb-1.5">Current Insulation</label>
                <select
                  id="teaser-condition"
                  name="condition"
                  class="w-full px-4 py-3 rounded-lg bg-white text-neutral-800 border-0 focus:ring-2 focus:ring-accent-orange focus:outline-none"
                >
                  <option value="poor">Little or No Insulation</option>
                  <option value="some" selected>Some Insulation</option>
                  <option value="decent">Decent Insulation</option>
                </select>
              </div>
            </div>
            <button
              type="submit"
              class="btn-primary text-lg px-8 py-4 w-full sm:w-auto"
            >
              Calculate My Savings &rarr;
            </button>
          </form>
        </div>
      </div>
    </section>

    <script>
      const form = document.getElementById('savings-teaser-form') as HTMLFormElement;
      form?.addEventListener('submit', (e) => {
        e.preventDefault();
        const zip = (form.querySelector('[name="zip"]') as HTMLInputElement)?.value || '';
        const sqft = (form.querySelector('[name="sqft"]') as HTMLInputElement)?.value || '';
        const condition = (form.querySelector('[name="condition"]') as HTMLSelectElement)?.value || '';
        const params = new URLSearchParams();
        if (zip) params.set('zip', zip);
        if (sqft) params.set('sqft', sqft);
        if (condition) params.set('condition', condition);
        window.location.href = `/savings-calculator?${params.toString()}`;
      });
    </script>

    <!-- Testimonials -->
    <section class="section-padding bg-white">
      <div class="container-narrow">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">What Our Customers Say</h2>
          <div class="flex items-center justify-center gap-2 mb-2">
            <div class="flex text-accent-orange text-xl">★★★★★</div>
            <span class="text-neutral-600 font-medium">{company.stats.googleRating} Stars</span>
          </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {displayTestimonials.map((review) => (
            <div class="bg-neutral-50 rounded-xl p-6 border border-neutral-200">
              <div class="flex text-accent-orange mb-3">★★★★★</div>
              <p class="text-neutral-700 text-sm mb-4 italic">"{review.text}"</p>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-brand-blue rounded-full flex items-center justify-center text-white font-bold text-sm">
                  {review.name.charAt(0)}
                </div>
                <div>
                  <p class="font-semibold text-sm text-neutral-800">{review.name}</p>
                  <p class="text-xs text-neutral-500">{review.source}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/reviews" class="btn-outline">Read All Reviews</a>
        </div>
      </div>
    </section>

    <!-- Service Areas -->
    <section class="section-padding bg-neutral-50">
      <div class="container-narrow">
        <div class="text-center mb-12">
          <h2 class="font-display text-3xl md:text-4xl font-bold text-brand-blue mb-4">Serving Oklahoma Statewide</h2>
          <p class="text-lg text-neutral-600 max-w-2xl mx-auto">We provide professional spray foam insulation across Oklahoma. Click your area to learn more.</p>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {cities.map((city) => (
            <a href={`/service-areas/${city.slug}`} class="bg-white rounded-lg p-4 text-center shadow-sm border border-neutral-200 hover:border-accent-orange hover:shadow-md transition-all">
              <p class="font-display font-bold text-brand-blue">{city.name}</p>
              <p class="text-xs text-neutral-500 mt-1">{city.state}</p>
            </a>
          ))}
        </div>
        <div class="text-center mt-8">
          <a href="/service-areas" class="btn-outline">View All Service Areas</a>
        </div>
      </div>
    </section>

    <!-- Quote Form -->
    <section id="quote" class="section-padding bg-brand-blue">
      <div class="container-narrow">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
          <div>
            <div class="mb-8">
              <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Get Your Free Estimate</h2>
              <p class="text-lg text-blue-200">Tell us about your project and we'll get back to you within 24 hours with a custom quote.</p>
            </div>
            <QuoteForm client:visible />
          </div>
          <div class="hidden lg:block space-y-4">
            <img
              src="/images/spray-foam-insulation-technician-full-safety-gear-oklahoma.jpg"
              alt="Spray foam insulation technician in full safety gear ready for application in Oklahoma"
              width="600"
              height="400"
              loading="lazy"
              class="w-full rounded-xl shadow-lg"
            />
            <img
              src="/images/spray-foam-gun-applying-closed-cell-insulation-closeup.jpg"
              alt="Close-up of spray foam gun applying closed cell insulation in Oklahoma"
              width="600"
              height="300"
              loading="lazy"
              class="w-full rounded-xl shadow-lg"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <CTASection />
  </div>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CTASection from '../../components/CTASection.astro';
import { services } from '../../data/services';
import { cities } from '../../data/cities';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

const siteURL = 'https://rockingradsprayfoam.com';

// Build TOC from H2 headings
const toc = headings.filter(h => h.depth === 2);

// Check if there's an FAQ section
const hasFAQ = headings.some(h => h.text.toLowerCase().includes('faq') || h.text.toLowerCase().includes('frequently'));

// Related services
const relatedServiceData = post.data.relatedServices
  ? services.filter(s => post.data.relatedServices!.includes(s.slug))
  : [];

// Related cities
const relatedCityData = post.data.relatedCities
  ? cities.filter(c => post.data.relatedCities!.includes(c.slug))
  : [];

// FAQ schema auto-detection
const faqHeadings = headings.filter(h =>
  h.text.toLowerCase().includes('faq') || h.text.toLowerCase().includes('frequently asked')
);
// If FAQ headings exist, gather sub-headings (H3s after the FAQ H2) as question/answer pairs
let faqSchema: object | null = null;
if (faqHeadings.length > 0) {
  const faqIndex = headings.findIndex(h => h === faqHeadings[0]);
  const faqQuestions: { question: string; slug: string }[] = [];
  for (let i = faqIndex + 1; i < headings.length; i++) {
    if (headings[i].depth <= 2) break; // stop at next H2 or higher
    if (headings[i].depth === 3) {
      faqQuestions.push({ question: headings[i].text, slug: headings[i].slug });
    }
  }
  if (faqQuestions.length > 0) {
    faqSchema = {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqQuestions.map(q => ({
        '@type': 'Question',
        name: q.question,
        acceptedAnswer: {
          '@type': 'Answer',
          // Answer text is rendered in the MDX content; schema references the on-page section
          text: `See the full answer in the article section: #${q.slug}`,
        },
      })),
    };
  }
}

// Article schema
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.seoTitle || post.data.title,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated || post.data.date).toISOString(),
  author: {
    '@type': 'Organization',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Rocking Rad Spray Foam LLC',
    url: siteURL,
  },
  description: post.data.description,
  image: post.data.image ? `${siteURL}${post.data.image}` : undefined,
};

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Blog', url: '/blog' },
  { name: post.data.title, url: `/blog/${post.id}` },
];

// Get all non-draft posts for prev/next navigation
const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
---

<BaseLayout
  title={post.data.seoTitle || `${post.data.title} | Rocking Rad Spray Foam`}
  description={post.data.description}
  schema={articleSchema}
  breadcrumbs={breadcrumbs}
>
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} slot="head" />
  )}
  <article class="section-padding">
    <div class="max-w-7xl mx-auto">
      <!-- Breadcrumb -->
      <nav class="text-sm text-neutral-500 mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2">
          <li><a href="/" class="hover:text-brand-blue">Home</a></li>
          <li>/</li>
          <li><a href="/blog" class="hover:text-brand-blue">Blog</a></li>
          <li>/</li>
          <li class="text-neutral-700 font-medium truncate">{post.data.title}</li>
        </ol>
      </nav>

      <div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-12">
        <!-- Main Content -->
        <div>
          <!-- Header -->
          <header class="mb-8">
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-block px-3 py-1 bg-accent-orange/10 text-accent-orange text-sm font-semibold rounded-full">
                {post.data.category}
              </span>
              <span class="text-sm text-neutral-500">{post.data.readTime}</span>
            </div>
            <h1 class="font-display font-extrabold text-3xl sm:text-4xl lg:text-5xl text-brand-blue mb-4">
              {post.data.title}
            </h1>
            <div class="flex items-center gap-4 text-sm text-neutral-500">
              <span>By {post.data.author}</span>
              <span>&bull;</span>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              {post.data.updated && (
                <>
                  <span>&bull;</span>
                  <span class="text-green-600 font-medium">
                    Updated {post.data.updated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </span>
                </>
              )}
            </div>
          </header>

          {post.data.image && (
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full rounded-xl mb-8 aspect-[2/1] object-cover bg-neutral-100"
              loading="eager"
            />
          )}

          <!-- Article Content -->
          <div class="prose prose-lg max-w-none
            prose-headings:font-display prose-headings:text-brand-blue
            prose-a:text-accent-orange prose-a:no-underline hover:prose-a:underline
            prose-strong:text-neutral-800
            prose-table:text-sm
            prose-th:bg-brand-blue prose-th:text-white prose-th:font-semibold
            prose-td:border-neutral-200
          ">
            <Content />
          </div>

          <!-- Related Services -->
          {relatedServiceData.length > 0 && (
            <div class="mt-12 pt-8 border-t border-neutral-200">
              <h2 class="font-display font-bold text-xl text-brand-blue mb-4">Related Services</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {relatedServiceData.map(service => (
                  <a href={`/services/${service.slug}`} class="block p-4 bg-neutral-50 rounded-lg hover:bg-neutral-100 transition-colors">
                    <h3 class="font-semibold text-brand-blue mb-1">{service.shortName}</h3>
                    <p class="text-sm text-neutral-600">{service.tagline}</p>
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Related Cities -->
          {relatedCityData.length > 0 && (
            <div class="mt-12 pt-8 border-t border-neutral-200">
              <h2 class="font-display font-bold text-xl text-brand-blue mb-4">Service Areas Mentioned</h2>
              <div class="flex flex-wrap gap-2">
                {relatedCityData.map(city => (
                  <a href={`/service-areas/${city.slug}`} class="inline-block px-3 py-1.5 bg-neutral-50 border border-neutral-200 rounded-full text-sm text-neutral-700 hover:border-brand-blue hover:text-brand-blue transition-colors">
                    {city.name}, {city.state}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Prev/Next Navigation -->
          <nav class="mt-12 pt-8 border-t border-neutral-200 grid grid-cols-1 sm:grid-cols-2 gap-4">
            {prevPost && (
              <a href={`/blog/${prevPost.id}`} class="group p-4 bg-neutral-50 rounded-lg hover:bg-neutral-100 transition-colors">
                <span class="text-xs text-neutral-500 uppercase tracking-wide">&larr; Previous</span>
                <p class="font-semibold text-brand-blue group-hover:text-brand-blue-light mt-1 text-sm">{prevPost.data.title}</p>
              </a>
            )}
            {nextPost && (
              <a href={`/blog/${nextPost.id}`} class="group p-4 bg-neutral-50 rounded-lg hover:bg-neutral-100 transition-colors sm:text-right">
                <span class="text-xs text-neutral-500 uppercase tracking-wide">Next &rarr;</span>
                <p class="font-semibold text-brand-blue group-hover:text-brand-blue-light mt-1 text-sm">{nextPost.data.title}</p>
              </a>
            )}
          </nav>
        </div>

        <!-- Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-24 space-y-8">
            <!-- Table of Contents -->
            {toc.length > 0 && (
              <div class="bg-neutral-50 rounded-xl p-6">
                <h3 class="font-display font-bold text-sm uppercase tracking-wide text-neutral-500 mb-3">Table of Contents</h3>
                <nav>
                  <ol class="space-y-2">
                    {toc.map(heading => (
                      <li>
                        <a href={`#${heading.slug}`} class="text-sm text-neutral-600 hover:text-brand-blue transition-colors">
                          {heading.text}
                        </a>
                      </li>
                    ))}
                  </ol>
                </nav>
              </div>
            )}

            <!-- CTA Card -->
            <div class="bg-brand-blue text-white rounded-xl p-6">
              <h3 class="font-display font-bold text-lg mb-2">Get Your Free Estimate</h3>
              <p class="text-sm text-neutral-200 mb-4">No obligation. Most quotes delivered same-day.</p>
              <a href="/contact" class="btn-primary w-full text-sm text-center block">
                Request Estimate
              </a>
              <a href="tel:5803205620" class="block text-center mt-3 text-accent-orange-light hover:text-accent-orange font-semibold text-sm">
                (580) 320-5620
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>

  <CTASection />
</BaseLayout>
